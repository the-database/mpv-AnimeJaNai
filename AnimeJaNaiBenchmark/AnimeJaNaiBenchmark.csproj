<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>AnimeJaNaiBenchmark</AssemblyName>
    <InvariantGlobalization>true</InvariantGlobalization>
    <!-- RID + self-contained come from the publish command (win-x64 / linux-x64);
         the Manager's "Run Benchmarks" button and the benchmark launcher both
         invoke this same tool on either OS. -->
  </PropertyGroup>

</Project>
